# beanies.family - Environment Variables

# Google OAuth (required for cloud sync - Phase 2)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-api-key

# Family Registry API (cloud registry for magic links and file recovery)
VITE_REGISTRY_API_URL=https://api.beanies.family
VITE_REGISTRY_API_KEY=your-registry-api-key

# Invite-only gate (beta)
# Comma-separated SHA-256 hashes of valid invite tokens (hex)
# Generate: echo -n "my-token" | sha256sum | cut -d' ' -f1
VITE_INVITE_BEAN_HASHES=
# Slack incoming webhook URL for invite request notifications
VITE_INVITE_WEBHOOK_URL=

# Note: AI API keys are stored locally in the app settings,
# not in environment variables. Users enter their own keys
# in the Settings page for privacy.
